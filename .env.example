# Governor OS Web Server — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
#
# Usage with Docker Compose (from repo root):
#   cp .env.example .env
#   # Edit .env and fill in secrets
#   docker compose up -d

# ── Server ─────────────────────────────────────────────────────────────────────

# Port the HTTP server listens on.
# Default: 3000
PORT=3000

# ── License & Auth ─────────────────────────────────────────────────────────────

# Secret used to validate plain license-key bearer tokens (single-tenant mode).
# When unset, any non-empty key is accepted (development mode only).
# Generate with: openssl rand -hex 32
LICENSE_SECRET=change-me-to-a-random-secret

# HMAC secret for signing and verifying Governor OS session tokens.
# Required in production — tokens won't survive restarts when unset (dev mode).
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-session-secret

# Secret that protects the /admin/orgs endpoints (POST, GET, DELETE).
# When unset, all admin endpoints return 503 — set this before going to production.
# Generate with: openssl rand -hex 32
ADMIN_SECRET=change-me-to-a-random-admin-secret

# ── File Persistence ──────────────────────────────────────────────────────────

# Path to the JSON file used to persist the organization registry across restarts.
# Default: data/orgs.json (relative to the working directory inside the container)
# ORGS_FILE=data/orgs.json

# Path to the NDJSON file used as the durable audit-job log.
# Default: data/audit-log.ndjson (relative to the working directory inside the container)
# AUDIT_LOG_FILE=data/audit-log.ndjson

# Static org registry seed — JSON array of { id, licenseKey, allowedSubs }.
# Useful for bootstrapping the registry without a running admin API.
# Env-seeded entries override conflicting ORGS_FILE entries on startup.
# ORGS_CONFIG=[{"id":"acme","licenseKey":"lk-secret","allowedSubs":["repo:acme/*"]}]

# ── OIDC / GitHub Integration ─────────────────────────────────────────────────

# GitHub OIDC JWKS endpoint (default shown — only override for GitHub Enterprise).
# JWKS_URL=https://token.actions.githubusercontent.com/.well-known/jwks

# Expected OIDC issuer (default: https://token.actions.githubusercontent.com).
# OIDC_ISSUER=https://token.actions.githubusercontent.com

# Expected OIDC audience (default: governor-os).
# OIDC_AUDIENCE=governor-os

# ── Database (future) ──────────────────────────────────────────────────────────

# PostgreSQL connection string for the Governor OS database.
# Example: postgresql://user:password@localhost:5432/governor_os
# DATABASE_URL=postgresql://user:password@localhost:5432/governor_os
