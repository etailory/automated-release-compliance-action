# Governor OS Web Server — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.

# ── Server ─────────────────────────────────────────────────────────────────────

# Port the HTTP server listens on.
# Default: 3000
PORT=3000

# ── License & Auth ─────────────────────────────────────────────────────────────

# Secret used to sign and verify Governor OS session tokens.
# Generate with: openssl rand -hex 32
LICENSE_SECRET=change-me-to-a-random-secret

# ── Database (future) ──────────────────────────────────────────────────────────

# PostgreSQL connection string for the Governor OS database.
# Example: postgresql://user:password@localhost:5432/governor_os
# DATABASE_URL=postgresql://user:password@localhost:5432/governor_os

# ── OIDC / GitHub Integration (future) ────────────────────────────────────────

# GitHub OIDC JWKS endpoint (default shown — only override for GitHub Enterprise).
# GITHUB_OIDC_JWKS_URL=https://token.actions.githubusercontent.com/.well-known/jwks

# ── Observability (future) ────────────────────────────────────────────────────

# Log level: trace | debug | info | warn | error
# LOG_LEVEL=info
